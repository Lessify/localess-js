  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.0.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  },
  "engines": {
    "node": ">= 20.0.0"
  }
}
