{
  "name": "@localess/client",
  "version": "3.0.5",
  "description": "Universal JavaScript/TypeScript SDK for Localess's API.",
  "keywords": [
    "localess",
    "sdk",
    "api",
    "client",
    "javascript",
    "typescript"
  ],
  "author": "Lessify",
