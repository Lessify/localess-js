      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "localess": "./dist/index.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lessify/localess-js.git",
    "directory": "packages/cli"
  },
  "bugs": {
