{
  "name": "@localess/cli",
  "version": "0.0.4",
  "description": "Localess Command Line.",
  "keywords": [
    "localess",
    "cli",
    "node",
    "javascript",
    "typescript"
  ],
  "author": "Lessify",
  "homepage": "https://github.com/Lessify/localess-js",
  "sideEffects": false,

  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "localess": "./dist/index.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lessify/localess-js.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Lessify/localess-js/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --shims",
    "test": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "chalk": "^5.6.2",
    "openapi-typescript": "^7.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">= 20.0.0"
  }
}
