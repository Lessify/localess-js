{
  "name": "@localess/cli",
  "version": "3.0.1",
  "description": "Localess Command Line.",
  "keywords": [
    "localess",
    "cli",
    "node",
    "javascript",
    "typescript"
  ],
  "author": "Lessify",
  "homepage": "https://github.com/Lessify/localess-js",
  "sideEffects": false,
  "files": [
    "dist",
    "SKILL.md"
