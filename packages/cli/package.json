    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "orval": "^8.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "openapi3-ts": "^4.5.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4"
  },
  "engines": {
    "node": ">= 20.0.0"
  }
}
